<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".moreFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Profile Header -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profileIconCard"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardBackgroundColor="#2F80ED"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp"
                    android:src="@drawable/outline_article_person_24"
                    app:tint="#FFFFFF" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/adminPanelTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Admin Panel"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/profileIconCard"
                app:layout_constraintTop_toTopOf="@id/profileIconCard" />

            <TextView
                android:id="@+id/adminPanelSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage your account &amp; settings"
                android:textColor="#888888"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@id/adminPanelTitle"
                app:layout_constraintTop_toBottomOf="@id/adminPanelTitle" />

            <!-- GENERAL Section -->
            <TextView
                android:id="@+id/lblGeneral"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="GENERAL"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/profileIconCard" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGeneral"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="#F0F0F0"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/lblGeneral">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Settings -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/btnSettings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:padding="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icSettingsContainer"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:cardBackgroundColor="#F5F6F8"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/settings_svgrepo_com"
                                app:tint="#555555" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tvSettings"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Settings"
                            android:textColor="#000000"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toStartOf="@+id/arrowSettings"
                            app:layout_constraintStart_toEndOf="@id/icSettingsContainer"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="App preferences &amp; configuration"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            app:layout_constraintEnd_toStartOf="@+id/arrowSettings"
                            app:layout_constraintStart_toStartOf="@id/tvSettings"
                            app:layout_constraintTop_toBottomOf="@id/tvSettings" />

                        <ImageView
                            android:id="@+id/arrowSettings"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_media_play"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#CCCCCC" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginHorizontal="16dp"/>

                    <!-- Account -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/btnAccount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:padding="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icAccountContainer"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:cardBackgroundColor="#F5F6F8"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/person"
                                app:tint="#555555" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tvAccount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Account"
                            android:textColor="#000000"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toStartOf="@+id/arrowAccount"
                            app:layout_constraintStart_toEndOf="@id/icAccountContainer"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Profile &amp; personal information"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            app:layout_constraintEnd_toStartOf="@+id/arrowAccount"
                            app:layout_constraintStart_toStartOf="@id/tvAccount"
                            app:layout_constraintTop_toBottomOf="@id/tvAccount" />

                        <ImageView
                            android:id="@+id/arrowAccount"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_media_play"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#CCCCCC" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginHorizontal="16dp"/>

                    <!-- Reports -->

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- COMMUNICATION Section -->
            <TextView
                android:id="@+id/lblCommunication"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="COMMUNICATION"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardGeneral" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCommunication"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="#F0F0F0"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/lblCommunication">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/btnNotifyTenants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/icNotifyContainer"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:cardBackgroundColor="#F5F6F8"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/bell_svgrepo_com"
                            app:tint="#555555" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvNotifyTenants"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Notify Tenants"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/arrowNotify"
                        app:layout_constraintStart_toEndOf="@id/icNotifyContainer"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Send announcements &amp; alerts"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toStartOf="@+id/arrowNotify"
                        app:layout_constraintStart_toStartOf="@id/tvNotifyTenants"
                        app:layout_constraintTop_toBottomOf="@id/tvNotifyTenants" />

                    <ImageView
                        android:id="@+id/arrowNotify"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_media_play"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#CCCCCC" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Logout Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#FFF5F5"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#FFE0E0"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/cardCommunication">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/icLogoutContainer"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:cardBackgroundColor="#FFE0E0"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_revert"
                            app:tint="#FF4D4D" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvLogout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Logout"
                        android:textColor="#FF4D4D"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/arrowLogout"
                        app:layout_constraintStart_toEndOf="@id/icLogoutContainer"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Sign out of your account"
                        android:textColor="#FF8080"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toStartOf="@+id/arrowLogout"
                        app:layout_constraintStart_toStartOf="@id/tvLogout"
                        app:layout_constraintTop_toBottomOf="@id/tvLogout" />

                    <ImageView
                        android:id="@+id/arrowLogout"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_media_play"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#FF8080" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Footer Version Info -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="PropTrack v1.0.0"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardLogout" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>