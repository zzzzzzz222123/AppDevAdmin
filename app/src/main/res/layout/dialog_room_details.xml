<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="24dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <!-- Header Section -->
                <TextView
                    android:id="@+id/txtRoomTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="Room 101 - Studio"
                    android:textColor="#000000"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@+id/badgeStatus"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txtBuildingTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Sunrise Residences"
                    android:textColor="#888888"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="@+id/txtRoomTitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/txtRoomTitle" />

                <TextView
                    android:id="@+id/badgeStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/badge_occupied"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Occupied"
                    android:textColor="#2E7D32"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/headerDivider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:background="#F0F0F0"
                    app:layout_constraintTop_toBottomOf="@id/txtBuildingTitle" />

                <!-- Room Details -->
                <TextView
                    android:id="@+id/lblRoomDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="ROOM DETAILS"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/headerDivider" />

                <!-- Room Type -->
                <ImageView
                    android:id="@+id/icType"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/outline_aq_indoor_24"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/lblRoomDetails"
                    app:tint="#888888" />

                <TextView
                    android:id="@+id/lblType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Room Type"
                    android:textColor="#555555"
                    android:textSize="15sp"
                    app:layout_constraintBottom_toBottomOf="@id/icType"
                    app:layout_constraintStart_toEndOf="@id/icType"
                    app:layout_constraintTop_toTopOf="@id/icType" />

                <TextView
                    android:id="@+id/valType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Studio"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/icType"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/icType" />

                <!-- Building -->
                <ImageView
                    android:id="@+id/icBuilding"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/baseline_dashboard_24"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/icType"
                    app:tint="#888888" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Building"
                    android:textColor="#555555"
                    android:textSize="15sp"
                    app:layout_constraintBottom_toBottomOf="@id/icBuilding"
                    app:layout_constraintStart_toEndOf="@id/icBuilding"
                    app:layout_constraintTop_toTopOf="@id/icBuilding" />

                <TextView
                    android:id="@+id/valBuilding"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:gravity="end"
                    android:text="Sunrise Residences"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/icBuilding"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/icBuilding"
                    app:layout_constraintTop_toTopOf="@id/icBuilding" />

                <!-- Monthly Rent -->
                <ImageView
                    android:id="@+id/icRent"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/outline_attach_money_24"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/valBuilding"
                    app:tint="#888888" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Monthly Rent"
                    android:textColor="#555555"
                    android:textSize="15sp"
                    app:layout_constraintBottom_toBottomOf="@id/icRent"
                    app:layout_constraintStart_toEndOf="@id/icRent"
                    app:layout_constraintTop_toTopOf="@id/icRent" />

                <TextView
                    android:id="@+id/valRent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱8,500/mo"
                    android:textColor="#2F80ED"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/icRent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/icRent" />

                <!-- Floor -->
                <ImageView
                    android:id="@+id/icFloor"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/outline_aq_indoor_24"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/icRent"
                    app:tint="#888888" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Floor"
                    android:textColor="#555555"
                    android:textSize="15sp"
                    app:layout_constraintBottom_toBottomOf="@id/icFloor"
                    app:layout_constraintStart_toEndOf="@id/icFloor"
                    app:layout_constraintTop_toTopOf="@id/icFloor" />

                <TextView
                    android:id="@+id/valFloor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1st Floor"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/icFloor"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/icFloor" />

                <View
                    android:id="@+id/detailsDivider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:background="#F0F0F0"
                    app:layout_constraintTop_toBottomOf="@id/icFloor" />

                <!-- Tenant Information Section -->
                <TextView
                    android:id="@+id/lblTenantInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="TENANT INFORMATION"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/detailsDivider" />

                <!-- Tenant Name Row -->
                <ImageView
                    android:id="@+id/icTenant"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/outline_article_person_24"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/lblTenantInfo"
                    app:tint="#888888" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Tenant"
                    android:textColor="#555555"
                    android:textSize="15sp"
                    app:layout_constraintBottom_toBottomOf="@id/icTenant"
                    app:layout_constraintStart_toEndOf="@id/icTenant"
                    app:layout_constraintTop_toTopOf="@id/icTenant" />

                <TextView
                    android:id="@+id/valTenant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Maria Santos"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/icTenant"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/icTenant" />

                <!-- Lease Start Row -->
                <ImageView
                    android:id="@+id/icLeaseStart"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="16dp"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/icTenant"
                    app:tint="#888888" />

                <TextView
                    android:id="@+id/lblLeaseStart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Lease Start"
                    android:textColor="#555555"
                    android:textSize="15sp"
                    app:layout_constraintBottom_toBottomOf="@id/icLeaseStart"
                    app:layout_constraintStart_toEndOf="@id/icLeaseStart"
                    app:layout_constraintTop_toTopOf="@id/icLeaseStart" />

                <TextView
                    android:id="@+id/valLeaseStart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jan 15, 2024"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/icLeaseStart"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/icLeaseStart" />

                <!-- Lease End Row -->
                <ImageView
                    android:id="@+id/icLeaseEnd"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="16dp"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/icLeaseStart"
                    app:tint="#888888" />

                <TextView
                    android:id="@+id/lblLeaseEnd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Lease End"
                    android:textColor="#555555"
                    android:textSize="15sp"
                    app:layout_constraintBottom_toBottomOf="@id/icLeaseEnd"
                    app:layout_constraintStart_toEndOf="@id/icLeaseEnd"
                    app:layout_constraintTop_toTopOf="@id/icLeaseEnd" />

                <TextView
                    android:id="@+id/valLeaseEnd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jan 14, 2025"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/icLeaseEnd"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/icLeaseEnd" />

                <!-- Action Buttons -->
                <Button
                    android:id="@+id/btnCloseDetails"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginEnd="12dp"
                    android:text="Close"
                    android:textAllCaps="false"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    app:layout_constraintEnd_toStartOf="@+id/btnEditFromDetails"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/icLeaseEnd"
                    app:strokeColor="#EEEEEE"
                    app:strokeWidth="1dp" />

                <Button
                    android:id="@+id/btnEditFromDetails"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:backgroundTint="#2F80ED"
                    android:paddingHorizontal="16dp"
                    android:text="Edit Room"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_edit"
                    app:layout_constraintBottom_toBottomOf="@id/btnCloseDetails"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1.3"
                    app:layout_constraintStart_toEndOf="@id/btnCloseDetails"
                    app:layout_constraintTop_toTopOf="@id/btnCloseDetails" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>