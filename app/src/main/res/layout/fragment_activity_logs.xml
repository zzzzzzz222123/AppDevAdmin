<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLogs"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnActivityLogs"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/outline_arrow_back_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#000000" />

        <TextView
            android:id="@+id/lblLogs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Activity Logs"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Placeholder for potential Refresh or Export button -->
        <ImageButton
            android:id="@+id/btnRefreshLogs"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/stat_notify_sync"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#2F80ED" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Search Section -->
    <androidx.appcompat.widget.SearchView
        android:id="@+id/logSearchView"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/search_bg"
        app:iconifiedByDefault="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLogs"
        app:queryBackground="@android:color/transparent"
        app:queryHint="Search activity..."
        app:searchIcon="@drawable/search" />

    <!-- Filter Buttons Section -->
    <HorizontalScrollView
        android:id="@+id/filterScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/logSearchView">

        <LinearLayout
            android:id="@+id/logFilterContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/btnLogFilterAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/filter_btn_selector"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:text="All"
                android:textColor="@drawable/filter_text_selector"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnLogFilterTenant"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/filter_btn_selector"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Tenants"
                android:textColor="@drawable/filter_text_selector"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnLogFilterRoom"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/filter_btn_selector"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Rooms"
                android:textColor="@drawable/filter_text_selector"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnLogFilterPayment"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/filter_btn_selector"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Payments"
                android:textColor="@drawable/filter_text_selector"
                android:textSize="14sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/lblLogStats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="Showing recent activity"
        android:textColor="#777777"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filterScroll" />

    <!-- List -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerActivityLogs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lblLogStats"
        tools:listitem="@layout/item_log_activity" />


</androidx.constraintlayout.widget.ConstraintLayout>