<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/profileHeader"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBackProfile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/outline_arrow_back_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#000000" />

        <TextView
            android:id="@+id/tvProfileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Profile"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBackProfile"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@+id/profileFooter"
        app:layout_constraintTop_toBottomOf="@id/profileHeader">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profileImgCard"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="50dp"
                app:cardElevation="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeColor="#F0F0F0"
                app:strokeWidth="2dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Profile Picture"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery" />
            </com.google.android.material.card.MaterialCardView>

            <View
                android:id="@+id/statusIndicator"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:background="@drawable/badge_occupied"
                android:backgroundTint="#00C853"
                app:layout_constraintBottom_toBottomOf="@id/profileImgCard"
                app:layout_constraintEnd_toEndOf="@id/profileImgCard"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Carlos Mendoza"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/profileImgCard" />

            <TextView
                android:id="@+id/tvUserRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tenant"
                android:textColor="#888888"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvUserName" />

            <TextView
                android:id="@+id/tvActiveBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/badge_occupied"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="✓ Active"
                android:textColor="#2E7D32"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvUserRole" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/infoGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:paddingHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvActiveBadge">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/boxRoom"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:layout_constraintEnd_toStartOf="@+id/boxRentingSince"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/icRoomBox"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/door"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#2F80ED" />
                        <TextView
                            android:id="@+id/lblRoomBox"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Room"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/icRoomBox" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Unit 204-B"
                            android:textColor="#000000"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/lblRoomBox" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/boxRentingSince"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/boxRoom"
                    app:layout_constraintTop_toTopOf="parent">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/icCalendarBox"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_my_calendar"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#2F80ED" />
                        <TextView
                            android:id="@+id/lblRentingSince"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Renting Since"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/icCalendarBox" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jan 15, 2023"
                            android:textColor="#000000"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/lblRentingSince" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/boxRent"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:layout_constraintEnd_toStartOf="@+id/boxLeaseEnds"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/boxRoom">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/icRentBox"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/outline_attach_money_24"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#2F80ED" />
                        <TextView
                            android:id="@+id/lblRentBox"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Monthly Rent"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/icRentBox" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₱8,500"
                            android:textColor="#000000"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/lblRentBox" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/boxLeaseEnds"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/boxRent"
                    app:layout_constraintTop_toBottomOf="@id/boxRentingSince">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/icLeaseBox"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#2F80ED" />
                        <TextView
                            android:id="@+id/lblLeaseBox"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Lease Ends"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/icLeaseBox" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jan 14, 2025"
                            android:textColor="#000000"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/lblLeaseBox" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/lblContactHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="32dp"
                android:text="CONTACT INFORMATION"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/infoGrid" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="#F0F0F0"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/lblContactHeader">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <ImageView android:id="@+id/icPhone" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_call" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:tint="#2F80ED" />
                    <TextView android:id="@+id/lblPhone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phone Number" android:textColor="#888888" android:textSize="11sp" android:layout_marginStart="12dp" app:layout_constraintStart_toEndOf="@id/icPhone" app:layout_constraintTop_toTopOf="@id/icPhone"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+63 917 123 4567" android:textColor="#000000" android:textStyle="bold" app:layout_constraintStart_toStartOf="@id/lblPhone" app:layout_constraintTop_toBottomOf="@id/lblPhone"/>

                    <ImageView android:id="@+id/icEmail" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_dialog_email" android:layout_marginTop="20dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/icPhone" app:tint="#2F80ED" />
                    <TextView android:id="@+id/lblEmail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email Address" android:textColor="#888888" android:textSize="11sp" android:layout_marginStart="12dp" app:layout_constraintStart_toEndOf="@id/icEmail" app:layout_constraintTop_toTopOf="@id/icEmail"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="carlos.mendoza@email.com" android:textColor="#000000" android:textStyle="bold" app:layout_constraintStart_toStartOf="@id/lblEmail" app:layout_constraintTop_toBottomOf="@id/lblEmail"/>

                    <ImageView
                        android:id="@+id/icPass"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="20dp"
                        android:src="@drawable/password_lock_svgrepo_com"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/icEmail"
                        app:tint="#2F80ED" />
                    <TextView android:id="@+id/lblPass" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Password" android:textColor="#888888" android:textSize="11sp" android:layout_marginStart="12dp" app:layout_constraintStart_toEndOf="@id/icPass" app:layout_constraintTop_toTopOf="@id/icPass"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="••••••••••••" android:textColor="#000000" android:textStyle="bold" app:layout_constraintStart_toStartOf="@id/lblPass" app:layout_constraintTop_toBottomOf="@id/lblPass"/>

                    <ImageView android:id="@+id/icEmergency" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_dialog_info" android:layout_marginTop="20dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/icPass" app:tint="#2F80ED" />
                    <TextView android:id="@+id/lblEmergency" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Emergency Contact" android:textColor="#888888" android:textSize="11sp" android:layout_marginStart="12dp" app:layout_constraintStart_toEndOf="@id/icEmergency" app:layout_constraintTop_toTopOf="@id/icEmergency"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Maria Mendoza — +63 918 765 4321" android:textColor="#000000" android:textStyle="bold" app:layout_constraintStart_toStartOf="@id/lblEmergency" app:layout_constraintTop_toBottomOf="@id/lblEmergency"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/lblPaymentHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="32dp"
                android:text="PAYMENT STATUS"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardContact" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPayment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="#F0F0F0"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/lblPaymentHeader">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <TextView android:id="@+id/payDec" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="● December 2024" android:textColor="#00C853" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Paid" android:background="@drawable/badge_occupied" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:textColor="#2E7D32" android:textSize="11sp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/payDec"/>

                    <TextView android:id="@+id/payNov" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="● November 2024" android:textColor="#00C853" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/payDec"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Paid" android:background="@drawable/badge_occupied" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:textColor="#2E7D32" android:textSize="11sp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/payNov"/>

                    <TextView android:id="@+id/payJan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="● January 2025" android:textColor="#FFA000" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/payNov"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pending" android:background="@drawable/badge_vacant" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:textColor="#1976D2" android:textSize="11sp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/payJan"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/lblMaintenanceHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="32dp"
                android:text="MAINTENANCE REQUESTS"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardPayment" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="#F0F0F0"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/lblMaintenanceHeader">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/icM1"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/badge_vacant"
                        android:padding="6dp"
                        android:src="@drawable/maintenance_warning"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#1976D2" />
                    <TextView android:id="@+id/tvM1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Leaking Faucet" android:textStyle="bold" android:layout_marginStart="12dp" app:layout_constraintStart_toEndOf="@id/icM1" app:layout_constraintTop_toTopOf="@id/icM1"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Submitted Dec 20, 2024" android:textColor="#888888" android:textSize="11sp" app:layout_constraintStart_toStartOf="@id/tvM1" app:layout_constraintTop_toBottomOf="@id/tvM1"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ongoing" android:background="@drawable/badge_vacant" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:textColor="#1976D2" android:textSize="11sp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/profileFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnMessage"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:text="Message"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:layout_constraintEnd_toStartOf="@+id/btnEditProfile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="#EEEEEE" />

        <Button
            android:id="@+id/btnEditProfile"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#2F80ED"
            android:text="Edit Profile"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_edit"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnMessage"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>